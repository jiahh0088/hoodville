# ─── Required ──────────────────────────────────────────────────────────────────
# Your bot's token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# The Application/Client ID of your bot
CLIENT_ID=your_client_id_here

# The Guild (server) ID where slash commands will be registered
# Set to your OLD server ID (or the server you run commands from)
COMMAND_GUILD_ID=your_guild_id_here

# The Guild ID of the OLD server (source of members to invite)
OLD_GUILD_ID=your_old_guild_id_here

# ─── Optional ──────────────────────────────────────────────────────────────────
# Path to the SQLite database file (defaults to invite-log.db in project root)
DB_PATH=./invite-log.db

# Delay in milliseconds between each DM to respect Discord rate limits
# Minimum recommended: 1200ms. Lower = higher risk of rate limiting.
DM_DELAY_MS=1500

# Log level: debug | info | warn | error
LOG_LEVEL=info
