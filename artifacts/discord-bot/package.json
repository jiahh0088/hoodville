{
  "name": "@workspace/discord-bot",
  "version": "1.0.0",
  "private": true,
  "description": "Discord server migration bot — invites members from old server to new with presets and duplicate protection",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node --experimental-sqlite dist/index.js",
    "dev": "node --experimental-sqlite --loader ts-node/esm src/index.ts",
    "deploy-commands": "node --experimental-sqlite -r ts-node/register src/deploy-commands.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "discord.js": "^14.14.1",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  },
  "engines": {
    "node": ">=22"
  }
}
